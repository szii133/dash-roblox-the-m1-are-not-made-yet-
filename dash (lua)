local UIS = game:GetService("UserInputService")
local Players = game:GetService("Players")
local Debris = game:GetService("Debris")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
local char = player.Character or player.CharacterAdded:Wait()
local hum = char:WaitForChild("Humanoid")
local hrp = char:WaitForChild("HumanoidRootPart")
local animator = hum:WaitForChild("Animator")

-- Asset Folders Configuration
local animFolder = script:WaitForChild("Animations")
local vfxFolder = script:WaitForChild("VFX")
local sfxFolder = script:FindFirstChild("SFX") or Instance.new("Folder", script)

-- === SUPREME CONFIGURATION ===
local SPEED_FRONT = 88
local SPEED_SIDE = 68
local DASH_DURATION = 0.33
local COOLDOWN = 0.75
local DAMAGE = 18
local KNOCKBACK = 42
local lastDash = 0
local isDashing = false

-- 1. MATERIAL DETECTION SYSTEM (Advanced VFX Realism)
local function getFloorMaterial()
	local rayParams = RaycastParams.new()
	rayParams.FilterDescendantsInstances = {char}
	local result = workspace:Raycast(hrp.Position, Vector3.new(0, -6, 0), rayParams)
	if result then return result.Material else return Enum.Material.Plastic end
end

-- 2. ADVANCED SCREEN SHAKE MODULE (Sinusoidal Movement)
local function applyScreenShake(intensity, duration)
	local startTime = tick()
	local connection
	connection = RunService.RenderStepped:Connect(function()
		local elapsed = tick() - startTime
		if elapsed < duration then
			local weight = 1 - (elapsed / duration)
			local shake = Vector3.new(
				math.random(-15, 15) * intensity * weight / 100,
				math.random(-15, 15) * intensity * weight / 100,
				math.random(-15, 15) * intensity * weight / 100
			)
			hum.CameraOffset = shake
		else
			hum.CameraOffset = Vector3.new(0, 0, 0)
			connection:Disconnect()
		end
	end)
end

-- 3. DYNAMIC LIGHTING VFX (Neon Pulse)
local function emitLightPulse()
	local light = Instance.new("PointLight")
	light.Color = Color3.fromRGB(0, 170, 255)
	light.Range = 15
	light.Brightness = 3
	light.Parent = hrp

	local tween = TweenService:Create(light, TweenInfo.new(DASH_DURATION), {Brightness = 0, Range = 0})
	tween:Play()
	Debris:AddItem(light, DASH_DURATION)
end

-- 4. DYNAMIC DASH VFX (SMOKE & TRAIL INTEGRATION)
local function emitDashVFX()
	local trailTemplate = vfxFolder:FindFirstChild("DashTrail")
	if trailTemplate then
		local a0 = Instance.new("Attachment", hrp)
		local a1 = Instance.new("Attachment", hrp)
		a0.Position = Vector3.new(0, 1.2, 0); a1.Position = Vector3.new(0, -1.2, 0)
		local t = trailTemplate:Clone()
		t.Attachment0 = a0; t.Attachment1 = a1; t.Parent = hrp; t.Enabled = true
		Debris:AddItem(t, DASH_DURATION); Debris:AddItem(a0, DASH_DURATION + 0.1); Debris:AddItem(a1, DASH_DURATION + 0.1)
	end

	local smokeTemplate = vfxFolder:FindFirstChild("DashSmoke")
	if smokeTemplate then
		local s = smokeTemplate:Clone()
		s.Parent = hrp; s:Emit(25)
		local floor = getFloorMaterial()
		if floor == Enum.Material.Grass then s.Color = ColorSequence.new(Color3.fromRGB(80, 120, 80)) end
		Debris:AddItem(s, 2)
	end
	emitLightPulse()
end

-- 5. NEON AFTERIMAGE SYSTEM (Visual Persistence)
local function spawnAfterimage()
	task.spawn(function()
		for i = 1, 8 do
			if not isDashing then break end
			for _, p in pairs(char:GetChildren()) do
				if p:IsA("BasePart") and p.Transparency < 1 then
					local c = Instance.new("Part")
					c.Size = p.Size; c.CFrame = p.CFrame; c.Anchored = true; c.CanCollide = false
					c.Material = Enum.Material.Neon; c.Color = Color3.fromRGB(0, 180, 255)
					c.Transparency = 0.55; c.Parent = workspace.Terrain
					TweenService:Create(c, TweenInfo.new(0.45), {Transparency = 1, Color = Color3.new(1,1,1)}):Play()
					Debris:AddItem(c, 0.45)
				end
			end
			task.wait(DASH_DURATION / 8)
		end
	end)
end

-- 6. COMBAT IMPACT VFX (FLASH, SPARKS, DEBRIS INTEGRATION)
local function playImpactVFX(targetHrp)
	applyScreenShake(9, 0.22)
	local att = Instance.new("Attachment", workspace.Terrain)
	att.WorldPosition = targetHrp.Position

	local f = vfxFolder:FindFirstChild("ImpactFlash")
	local s = vfxFolder:FindFirstChild("ImpactSparks")
	local d = vfxFolder:FindFirstChild("ImpactDebris")

	if f then local c = f:Clone(); c.Parent = att; c:Emit(1) end
	if s then local c = s:Clone(); c.Parent = att; c:Emit(35) end
	if d then local c = d:Clone(); c.Parent = att; c:Emit(18) end

	Debris:AddItem(att, 2.5)
end

-- 7. SPHERECAST HITBOX ENGINE (Precision Detection)
local function startHitbox(dir)
	local hitFound = false
	local connection
	connection = RunService.Heartbeat:Connect(function()
		if hitFound or not isDashing then connection:Disconnect() return end
		local p = RaycastParams.new()
		p.FilterDescendantsInstances = {char}
		local r = workspace:Spherecast(hrp.Position, 3.8, dir * 4.8, p)
		if r and r.Instance then
			local eC = r.Instance.Parent
			local eH = eC:FindFirstChild("Humanoid")
			local eR = eC:FindFirstChild("HumanoidRootPart")
			if eH and eR and eH.Health > 0 then
				hitFound = true
				eH:TakeDamage(DAMAGE)
				playImpactVFX(eR)
				local k = Instance.new("BodyVelocity")
				k.MaxForce = Vector3.new(1.3, 1.3, 1.3) * 1e6
				k.Velocity = (dir * KNOCKBACK) + Vector3.new(0, 24, 0)
				k.Parent = eR; Debris:AddItem(k, 0.25)
			end
		end
	end)
end

-- === MAIN EXECUTION CORE ENGINE ===
local function performDash()
	if tick() - lastDash < COOLDOWN or isDashing then return end
	isDashing = true; lastDash = tick()
	local dV = hrp.CFrame.LookVector
	local aN = "Front"
	local s = SPEED_FRONT

	if UIS:IsKeyDown(Enum.KeyCode.S) then
		dV = -hrp.CFrame.LookVector; aN = "Back"; s = SPEED_SIDE
	elseif UIS:IsKeyDown(Enum.KeyCode.A) then
		dV = -hrp.CFrame.RightVector; aN = "Left"; s = SPEED_SIDE
	elseif UIS:IsKeyDown(Enum.KeyCode.D) then
		dV = hrp.CFrame.RightVector; aN = "Right"; s = SPEED_SIDE
	end

	emitDashVFX()
	spawnAfterimage()
	local a = animFolder:FindFirstChild(aN)
	if a then
		local t = animator:LoadAnimation(a)
		t.Priority = Enum.AnimationPriority.Action4
		t:Play(0.06); task.delay(DASH_DURATION, function() t:Stop(0.28) end)
	end

	local att = Instance.new("Attachment", hrp)
	local lv = Instance.new("LinearVelocity", att)
	lv.MaxForce = 7e6; lv.VectorVelocity = dV * s; lv.Attachment0 = att
	local ao = Instance.new("AlignOrientation", att)
	ao.MaxTorque = 2e7; ao.Attachment0 = att; ao.CFrame = hrp.CFrame

	startHitbox(dV)
	task.delay(DASH_DURATION, function()
		lv:Destroy(); ao:Destroy(); att:Destroy(); isDashing = false
	end)
end

-- Input Event Handling Connection
UIS.InputBegan:Connect(function(i, g)
	if not g and i.KeyCode == Enum.KeyCode.Q then performDash() end
end)

