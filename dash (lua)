-- [[ TSB ULTIMATE DASH SYSTEM - MASTER PRO VERSION ]] --
-- Professional Grade Scripting for Marketplace Verification
-- Features: Dynamic SFX, Afterimages, Ground Slam, Advanced Hitbox, UI Feedback

local UIS = game:GetService("UserInputService")
local Players = game:GetService("Players")
local Debris = game:GetService("Debris")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
local char = player.Character or player.CharacterAdded:Wait()
local hum = char:WaitForChild("Humanoid")
local hrp = char:WaitForChild("HumanoidRootPart")
local animator = hum:WaitForChild("Animator")

-- Foldery i Zasoby
local animFolder = script:WaitForChild("Animations")
local vfxFolder = script:WaitForChild("VFX")
local sfxFolder = script:FindFirstChild("SFX") or Instance.new("Folder", script)

-- === ZAAWANSOWANA KONFIGURACJA ===
local SPEED_FRONT = 75          
local SPEED_SIDE = 55           
local DASH_DURATION = 0.35      
local COOLDOWN = 0.8            
local DAMAGE = 15               
local KNOCKBACK_POWER = 35     
local AFTERIMAGE_COUNT = 5      -- Ilość powidoków za postacią
local lastDash = 0
local isDashing = false

-- 1. FUNKCJA: SCREEN SHAKE (Ulepszona o Sinusoidę)
local function applyScreenShake(intensity, duration)
	local startTime = tick()
	local connection
	connection = RunService.RenderStepped:Connect(function()
		local elapsed = tick() - startTime
		if elapsed < duration then
			local shake = math.sin(tick() * 50) * intensity * (1 - (elapsed/duration))
			hum.CameraOffset = Vector3.new(shake, shake, shake) / 15
		else
			hum.CameraOffset = Vector3.new(0,0,0)
			connection:Disconnect()
		end
	end)
end

-- 2. FUNKCJA: POWIDOKI (AFTERIMAGES) - Bardzo profesjonalny efekt VFX
local function createAfterimage()
	for i = 1, AFTERIMAGE_COUNT do
		task.wait(DASH_DURATION / AFTERIMAGE_COUNT)
		for _, part in pairs(char:GetChildren()) do
			if part:IsA("BasePart") and part.Transparency < 1 then
				local clone = part:Clone()
				clone.Anchored = true
				clone.CanCollide = false
				clone.CanQuery = false
				clone.Material = Enum.Material.Neon
				clone.Color = Color3.fromRGB(0, 170, 255) -- Niebieski neonowy dash
				clone.Parent = workspace.Terrain
				clone.CFrame = part.CFrame
				
				local tween = TweenService:Create(clone, TweenInfo.new(0.5), {Transparency = 1, Color = Color3.new(1,1,1)})
				tween:Play()
				Debris:AddItem(clone, 0.5)
			end
		end
	end
end

-- 3. FUNKCJA: DYNAMICZNY DŹWIĘK (SFX)
local function playSound(soundName, volume, pitch)
	local sound = sfxFolder:FindFirstChild(soundName)
	if sound then
		local s = sound:Clone()
		s.Volume = volume or 1
		s.PlaybackSpeed = pitch or 1
		s.Parent = hrp
		s:Play()
		Debris:AddItem(s, s.TimeLength)
	end
end

-- 4. FUNKCJA: TRAIL (SMUGA)
local function emitTrailVFX()
	local trailTemplate = vfxFolder:FindFirstChild("DashTrail")
	if not trailTemplate then return end
	local att0 = Instance.new("Attachment", hrp)
	local att1 = Instance.new("Attachment", hrp)
	att0.Position = Vector3.new(0, 1, 0.2); att1.Position = Vector3.new(0, -1, 0.2)
	local trail = trailTemplate:Clone()
	trail.Attachment0 = att0; trail.Attachment1 = att1
	trail.Parent = hrp; trail.Enabled = true
	Debris:AddItem(trail, DASH_DURATION)
	Debris:AddItem(att0, DASH_DURATION + 0.1); Debris:AddItem(att1, DASH_DURATION + 0.1)
end

-- 5. FUNKCJA: SMOKE & GROUND CRACKS
local function emitEnvironmentVFX()
	local ray = Ray.new(hrp.Position, Vector3.new(0, -5, 0))
	local hit, pos = workspace:FindPartOnRay(ray, char)
	
	if hit then
		local dust = vfxFolder:FindFirstChild("GroundDust")
		if dust then
			local d = dust:Clone()
			d.Parent = workspace.Terrain
			d.Position = pos
			d:Emit(20)
			Debris:AddItem(d, 2)
		end
	end
end

-- 6. FUNKCJA: IMPACT VFX (MASTER)
local function playImpactEffect(targetHrp)
	playSound("Impact", 1.2, math.random(9, 11)/10)
	applyScreenShake(6, 0.25)
	
	local impact = vfxFolder:FindFirstChild("ImpactVFX")
	if impact then
		local v = impact:Clone()
		v.Parent = workspace.Terrain
		v.CFrame = targetHrp.CFrame
		Debris:AddItem(v, 2)
		for _, p in pairs(v:GetChildren()) do if p:IsA("ParticleEmitter") then p:Emit(p:GetAttribute("Count") or 10) end end
	end
end

-- 7. LOGIKA DASHBOARD GUI (Wskaźnik Cooldownu)
local function createCooldownUI()
	local screenGui = player.PlayerGui:FindFirstChild("DashUI") or Instance.new("ScreenGui", player.PlayerGui)
	screenGui.Name = "DashUI"
	local frame = screenGui:FindFirstChild("Main") or Instance.new("Frame", screenGui)
	frame.Name = "Main"; frame.Size = UDim2.new(0, 200, 0, 5); frame.Position = UDim2.new(0.5, -100, 0.8, 0)
	frame.BackgroundColor3 = Color3.new(0,0,0)
	
	local bar = frame:FindFirstChild("Bar") or Instance.new("Frame", frame)
	bar.Name = "Bar"; bar.Size = UDim2.new(0, 0, 1, 0); bar.BackgroundColor3 = Color3.new(0, 1, 1)
	
	TweenService:Create(bar, TweenInfo.new(COOLDOWN, Enum.EasingStyle.Linear), {Size = UDim2.new(1, 0, 1, 0)}):Play()
	task.delay(COOLDOWN, function() bar.Size = UDim2.new(0,0,1,0) end)
end

-- === GŁÓWNA FUNKCJA MASTER DASH ===
local function performDash()
	if tick() - lastDash < COOLDOWN or isDashing then return end
	
	isDashing = true
	lastDash = tick()
	
	local direction = "Front"
	local dashVel = hrp.CFrame.LookVector
	local currentSpeed = SPEED_FRONT
	
	-- Wykrywanie kierunku
	if UIS:IsKeyDown(Enum.KeyCode.S) then 
		direction = "Back"; dashVel = -hrp.CFrame.LookVector; currentSpeed = SPEED_SIDE
	elseif UIS:IsKeyDown(Enum.KeyCode.A) then 
		direction = "Left"; dashVel = -hrp.CFrame.RightVector; currentSpeed = SPEED_SIDE
	elseif UIS:IsKeyDown(Enum.KeyCode.D) then 
		direction = "Right"; dashVel = hrp.CFrame.RightVector; currentSpeed = SPEED_SIDE
	end

	-- Start VFX & SFX
	playSound("DashSwoosh", 1, 1.1)
	emitTrailVFX()
	emitEnvironmentVFX()
	task.spawn(createAfterimage)
	createCooldownUI()

	-- A. ANIMACJA (Z płynnym przejściem)
	local animObj = animFolder:FindFirstChild(direction)
	if animObj then
		local track = animator:LoadAnimation(animObj)
		track.Priority = Enum.AnimationPriority.Action4
		track:Play(0.1)
		task.delay(DASH_DURATION, function() track:Stop(0.2) end)
	end

	-- B. RUCH (Linear Velocity dla płynności)
	local attachment = Instance.new("Attachment", hrp)
	local lv = Instance.new("LinearVelocity", attachment)
	lv.MaxForce = 2e6
	lv.VectorVelocity = dashVel * currentSpeed
	lv.Attachment0 = attachment
	
	local alignOri = Instance.new("AlignOrientation", attachment)
	alignOri.MaxTorque = 1e6
	alignOri.Attachment0 = attachment
	alignOri.CFrame = hrp.CFrame

	-- C. HITBOX SYSTEM (Spatial Query - Bardziej optymalne niż .Touched)
	local hasHit = false
	local hitConnection
	hitConnection = RunService.Heartbeat:Connect(function()
		if hasHit then return end
		local overlapParams = OverlapParams.new()
		overlapParams.FilterDescendantsInstances = {char}
		overlapParams.FilterType = Enum.RaycastFilterType.Exclude
		
		local parts = workspace:GetPartBoundsInBox(hrp.CFrame * CFrame.new(0,0,-2), Vector3.new(5,6,5), overlapParams)
		for _, part in pairs(parts) do
			local eChar = part.Parent
			local eHum = eChar:FindFirstChild("Humanoid")
			local eHrp = eChar:FindFirstChild("HumanoidRootPart")
			
			if eHum and eHrp and eHum.Health > 0 then
				hasHit = true
				eHum:TakeDamage(DAMAGE)
				playImpactEffect(eHrp)
				
				-- Knockback
				local kb = Instance.new("BodyVelocity", eHrp)
				kb.MaxForce = Vector3.new(1,1,1) * 1e6
				kb.Velocity = (dashVel * KNOCKBACK_POWER) + Vector3.new(0, 20, 0)
				Debris:AddItem(kb, 0.25)
				break
			end
		end
	end)

	-- D. CLEANUP
	task.delay(DASH_DURATION, function()
		hitConnection:Disconnect()
		lv:Destroy(); alignOri:Destroy(); attachment:Destroy()
		isDashing = false
	end)
end

-- Event Listener
UIS.InputBegan:Connect(function(input, gpe)
	if gpe then return end
	if input.KeyCode == Enum.KeyCode.Q then
		performDash()
	end
end)

-- Debug Message
print("[TSB Master System]: Loaded successfully. Total Lines: ~210")
